# =========================================================================
# TechInsight 環境変数テンプレート
# 使い方: `cp .env.example .env` してから必要に応じて編集
# `.env` は Git にコミットされません。本ファイル (.env.example) のみコミット対象です。
# 値を空のままにすると docker-compose.yml で定義されたデフォルトが使われます。
# =========================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=techinsight
POSTGRES_PASSWORD=techinsight_dev
POSTGRES_DB=techinsight
POSTGRES_PORT=5432

# ---------- Backend ----------
BACKEND_PORT=8000
# コンテナ間通信ではホスト名 "db" を使う（docker network 内の解決）
DATABASE_URL=postgresql+asyncpg://techinsight:techinsight_dev@db:5432/techinsight

# ---------- Frontend ----------
FRONTEND_PORT=3000
# ブラウザから直接叩く URL なので localhost を指定
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ---------- Embedding ----------
# "local" = sentence-transformers (API キー不要、デフォルト)
# "openai" = OpenAI text-embedding-3-small (OPENAI_API_KEY が必要)
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
